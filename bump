#!/usr/bin/env python3
"""Bump version in pyproject.toml, commit, tag, and push."""

import re
import subprocess
import sys
from pathlib import Path


def main():
    if len(sys.argv) != 2 or sys.argv[1] not in ("major", "minor", "patch"):
        print(f"Usage: {sys.argv[0]} <major|minor|patch>")
        sys.exit(1)

    part = sys.argv[1]
    pyproject = Path("pyproject.toml")
    if not pyproject.exists():
        print("Error: pyproject.toml not found (run from repo root)")
        sys.exit(1)

    text = pyproject.read_text()
    match = re.search(r'^version\s*=\s*"(\d+)\.(\d+)\.(\d+)"', text, re.MULTILINE)
    if not match:
        print("Error: could not find version in pyproject.toml")
        sys.exit(1)

    major, minor, patch = int(match.group(1)), int(match.group(2)), int(match.group(3))
    old_version = f"{major}.{minor}.{patch}"

    if part == "major":
        major += 1
        minor = 0
        patch = 0
    elif part == "minor":
        minor += 1
        patch = 0
    else:
        patch += 1

    new_version = f"{major}.{minor}.{patch}"
    text = text.replace(f'version = "{old_version}"', f'version = "{new_version}"', 1)
    pyproject.write_text(text)
    print(f"{old_version} -> {new_version}")

    tag = f"v{new_version}"
    subprocess.run(["git", "add", "-A"], check=True)
    subprocess.run(["git", "commit", "-m", f"v{new_version}"], check=True)
    subprocess.run(["git", "tag", tag], check=True)
    subprocess.run(["git", "push"], check=True)
    subprocess.run(["git", "push", "origin", tag], check=True)
    print(f"Done: tagged and pushed {tag}")


if __name__ == "__main__":
    main()
